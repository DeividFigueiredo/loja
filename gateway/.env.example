# Shopify (desativado se MEDUSA_BACKEND_URL + MEDUSA_PUBLISHABLE_KEY estiverem definidos)
SHOPIFY_SHOP=dindinhas
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_CLIENT_ID=seu_client_id
SHOPIFY_CLIENT_SECRET=sua_chave_secreta

# Medusa (tem prioridade sobre Shopify quando ambos estão presentes)
